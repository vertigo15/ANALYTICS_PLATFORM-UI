# ── Environment (dev | stg | prod) ───────────────────────────────────────────
APP_ENV=dev
NEXT_PUBLIC_APP_ENV=dev

# ── Analytics DB (read-only access — bi_readonly role) ───────────────────────
ANALYTICS_DB_HOST=your-azure-postgres-host.postgres.database.azure.com
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_USER=bi_readonly
ANALYTICS_DB_PASSWORD=your_secure_password_here
ANALYTICS_DB_SSLMODE=require

# ── API config ────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CACHE_TTL_SECONDS=3300

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
