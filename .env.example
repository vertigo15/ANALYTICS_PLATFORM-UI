# ── Active environment: dev | stg | prod ─────────────────────────────────────
# Change this value OR use: APP_ENV=stg make switch-stg
APP_ENV=dev

# ── Development DB ────────────────────────────────────────────────────────────
DEV_DB_HOST=dev-postgres.postgres.database.azure.com
DEV_DB_PORT=5432
DEV_DB_NAME=analytics_db
DEV_DB_USER=bi_readonly
DEV_DB_PASSWORD=REPLACE_WITH_DEV_PASSWORD
DEV_DB_SSLMODE=require

# ── Staging DB ────────────────────────────────────────────────────────────────
STG_DB_HOST=stg-postgres.postgres.database.azure.com
STG_DB_PORT=5432
STG_DB_NAME=analytics_db
STG_DB_USER=bi_readonly
STG_DB_PASSWORD=REPLACE_WITH_STG_PASSWORD
STG_DB_SSLMODE=require

# ── Production DB ─────────────────────────────────────────────────────────────
PROD_DB_HOST=prod-postgres.postgres.database.azure.com
PROD_DB_PORT=5432
PROD_DB_NAME=analytics_db
PROD_DB_USER=bi_readonly
PROD_DB_PASSWORD=REPLACE_WITH_PROD_PASSWORD
PROD_DB_SSLMODE=require

# ── API config ────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CACHE_TTL_SECONDS=3300

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
